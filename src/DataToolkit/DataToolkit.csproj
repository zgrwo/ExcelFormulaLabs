<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0-windows;net48</TargetFrameworks>
    <RootNamespace>ExcelVbaLibraries.DataToolkit</RootNamespace>
    <AssemblyName>DataToolkit</AssemblyName>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591;NU1701</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies.net48" Version="1.0.3">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>DataToolkit.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Foundation\Foundation.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ExcelDna.Integration" Version="1.8.0" />
    <PackageReference Include="ExcelDna.AddIn" Version="1.8.0">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <PackageReference Include="System.Data.SQLite.Core" Version="1.0.119" />
    <PackageReference Include="System.Text.Json" Version="8.0.4" />
  </ItemGroup>

  <!-- Generate correct .dna from templates per target (avoids cross-target DLL references) -->
  <Target Name="CleanStaleDna" BeforeTargets="GenerateDnaFromTemplate">
    <!-- Always clean up generated .dna from previous (possibly failed) builds -->
    <Delete Files="DataToolkit-AddIn.dna;DataToolkit-AddIn-net48.dna" />
  </Target>
  <Target Name="GenerateDnaFromTemplate" BeforeTargets="BeforeBuild" DependsOnTargets="CleanStaleDna">
    <Copy Condition="'$(TargetFramework)' == 'net8.0-windows'"
          SourceFiles="DataToolkit-AddIn-net8.dna.tpl"
          DestinationFiles="DataToolkit-AddIn.dna" />
    <Copy Condition="'$(TargetFramework)' == 'net48'"
          SourceFiles="DataToolkit-AddIn-net48.dna.tpl"
          DestinationFiles="DataToolkit-AddIn-net48.dna" />
  </Target>
  <Target Name="CleanGeneratedDna" AfterTargets="AfterBuild">
    <Delete Condition="'$(TargetFramework)' == 'net8.0-windows' and Exists('DataToolkit-AddIn.dna')"
            Files="DataToolkit-AddIn.dna" />
    <Delete Condition="'$(TargetFramework)' == 'net48' and Exists('DataToolkit-AddIn-net48.dna')"
            Files="DataToolkit-AddIn-net48.dna" />
  </Target>

</Project>
